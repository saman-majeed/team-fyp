rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admins collection
    match /admins/{adminId} {
      allow read: if true;
      allow write: if false; // Only via Admin SDK
    }

    // Tests collection
    match /tests/{testId} {
      allow read, write: if true;
    }

    // Candidates — can only read their own data
    match /candidates/{candidateId} {
      allow read, create, update: if true;
    }

    // Questions — read only during active test
    match /questions/{questionId} {
      allow read: if request.auth != null;
      allow write: if false; // Generated by Cloud Functions only
    }

    // Responses — candidates write their own
    match /responses/{responseId} {
      allow read: if isAdmin();
      allow create: if request.auth != null &&
        request.resource.data.candidateId == request.auth.uid;
      allow update: if false;
    }

    // Warnings — candidates create, admins read
    match /warnings/{warningId} {
      allow read, create: if true;
    }

    // Live sessions
    match /liveSessions/{sessionId} {
      allow read, write: if true;
    }

    // Results
    match /results/{resultId} {
      allow read, create: if true;
      allow update: if false;
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
  }
}